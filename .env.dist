# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=
PORT=

# Public API base URL used by generated Swagger docs.
# API_PUBLIC_URL=https://api.example.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_DSN=

# ── Session tokens ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=

# ── Auth ──────────────────────────────────────────────────────────────────────
# First user to sign up gets admin. Override with a specific email:
ADMIN_EMAIL=

# Base URL of the frontend — used for post-login redirects
FRONTEND_URL=

# ── OIDC (Supabase or any JWKS-compatible provider) ──────────────────────────
# JWKS endpoint — used to validate inbound access tokens at POST /auth/oidc/exchange
OIDC_JWKS_URL=

# Comma-separated list of OAuth providers enabled in your OIDC provider's dashboard.
# Controls which login buttons appear on the frontend. No credentials needed here.
OIDC_PROVIDERS=

# ── Local/self-hosted providers ───────────────────────────────────────────────
# Default base URL used by GET /ai/discover when no baseUrl query parameter is provided.
# OLLAMA_BASE_URL=http://localhost:11434

# ── Observability ─────────────────────────────────────────────────────────────
# Days to keep inference_logs and audit_logs before the nightly purge job removes them.
LOG_RETENTION_DAYS=

# ── Async jobs (SQS) ─────────────────────────────────────────────────────────
# When set, the job dispatcher publishes to this SQS queue instead of running
# jobs in a local goroutine. Leave empty for local/dev single-process mode.
SQS_QUEUE_URL=
# Example: SQS_QUEUE_URL=https://sqs.<region>.amazonaws.com/<account>/<queue>

# ── Cache & Rate limiting ──────────────────────────────────────────────────────
# "memory" (default) or "redis"
CACHE_BACKEND=
RATE_LIMIT_BACKEND=

# Redis connection — required when CACHE_BACKEND=redis or RATE_LIMIT_BACKEND=redis
CACHE_REDIS_ADDR=
CACHE_REDIS_PREFIX=

# ── Health checks ─────────────────────────────────────────────────────────────
# Seconds between provider health probes.
HEALTH_CHECK_INTERVAL_SECS=
